# Secrets Steam : conserver les vraies valeurs uniquement dans backend/.env.
STEAM_GSLT_TOKEN=
STEAM_WEBAPI_KEY=

CS2_IMAGE=joedwards32/cs2
CS2_DATA_PATH=/home/steam/cs2_data
SERVER_IP=10.255.0.26
PORT=3000
BIND_ADDRESS=0.0.0.0
BASE_PORT=27026
PORT_RANGE_SIZE=100
DYNAMIC_CS2_LAN=1

# Cle partagee uniquement entre le backend du site et cs2-manager-api.
SURFLAB_API_KEY=replace-with-a-random-64-character-secret
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

ALLOW_UNLISTED_MAPS=false
DEFAULT_SERVER_DURATION_MINUTES=60
MIN_SERVER_DURATION_MINUTES=15
MAX_SERVER_DURATION_MINUTES=480
MAX_ACTIVE_SERVERS=8
MAX_ACTIVE_PER_OWNER=2
MAX_PLAYERS_PER_SERVER=16
CREATE_RATE_LIMIT_PER_MINUTE=10

CONTAINER_MEMORY_MB=4096
CONTAINER_CPU_LIMIT=2
CONTAINER_PIDS_LIMIT=1024
BOOT_TIMEOUT_MS=900000
